# --- Database (Prisma, hosted on Supabase Postgres) ---
# Project Settings > Database > Connection string > URI
# Use the pooled "Transaction" connection string for DATABASE_URL (app runtime + serverless).
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the direct (non-pooled) connection string for migrations.
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# --- Founder Mode gate ---
# Bcrypt hash of the shared founder passphrase. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-passphrase', 10))"
# IMPORTANT: in .env files, Next.js expands $VAR syntax, which mangles bcrypt
# hashes (they start with $2b$). Escape every $ as \$ in .env* files, e.g.
# FOUNDER_PASSPHRASE_HASH="\$2b\$10\$abc..."
# This escaping is NOT needed when pasting the value into the Vercel dashboard
# (or any host that injects env vars directly) — paste the raw hash there.
FOUNDER_PASSPHRASE_HASH="\$2b\$10\$..."
# Random secret used to sign the founder-unlock session cookie (JWT). Generate with:
#   openssl rand -base64 32
FOUNDER_SESSION_SECRET="change-me-to-a-random-32-byte-secret"
