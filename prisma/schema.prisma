// Prisma schema for team.archivault.in
// No individual logins: /team/* is open to anyone with the link, and
// /founder/* is gated by a single shared passphrase (checked in app code,
// not modeled here). Nothing in this schema is tied to a user account.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CommissionType {
  flat
  percent
}

enum LeadStatus {
  new
  contacted
  follow_up
  converted
  lost
}

enum PayoutStatus {
  unpaid
  paid
}

model Lead {
  id      String     @id @default(uuid())
  name    String
  phone   String?
  company String?
  source  String?
  status  LeadStatus @default(new)
  notes   String?

  // Free-text — who's working this lead. Not a login/account, just a label
  // typed or picked from the rep list, so the founder tracker can still
  // total sales per person without any per-user auth.
  repName String?

  isSale          Boolean      @default(false)
  saleValue       Decimal?     @db.Decimal(12, 2)
  saleConfirmedAt DateTime?
  payoutStatus    PayoutStatus @default(unpaid)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([repName])
  @@map("leads")
}

// Per-rep commission configuration, keyed by the same free-text name used
// on Lead.repName. Lets founders set "specific to each intern" commission
// rates without needing accounts.
model RepCommission {
  repName        String         @id
  commissionType CommissionType @default(flat)
  commissionRate Decimal        @default(0) @db.Decimal(12, 2)
  createdAt      DateTime       @default(now())

  @@map("rep_commissions")
}

// Singleton doc — one shared private notes space for founders, hidden from
// the team but not split per-founder (both founders share one passphrase).
model FounderNote {
  id        String   @id @default(uuid())
  content   String   @default("")
  updatedAt DateTime @updatedAt

  @@map("founder_notes")
}

model WikiPage {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String
  order     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("wiki_pages")
}

model FaqItem {
  id       String  @id @default(uuid())
  question String
  answer   String
  category String?
  order    Int     @default(0)

  @@map("faq_items")
}

// Tracks failed founder-passphrase attempts per IP so a lockout can be
// enforced after repeated wrong guesses. Not tied to any account — just a
// brute-force guard on the one shared passphrase.
model PassphraseAttempt {
  ip             String    @id
  count          Int       @default(0)
  firstAttemptAt DateTime  @default(now())
  lockedUntil    DateTime?

  @@map("passphrase_attempts")
}
